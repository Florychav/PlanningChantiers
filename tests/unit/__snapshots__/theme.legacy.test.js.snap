// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`Q9 — figeage bloc :root[data-theme="light"] > planning-montage.html : bloc light fige 1`] = `
":root[data-theme="light"]{
  /* Surfaces : inversion. */
  --bg:#FFFFFF;            /* dark: #0A0F1E -> light: white */
  --bg-elev-1:#F9FAFB;     /* dark: #111827 -> light: gray-50 */
  --bg-elev-2:#F3F4F6;     /* dark: #0F1626 -> light: gray-100 */
  --bg-elev-3:#E5E7EB;     /* dark: #1A2233 -> light: gray-200 */
  --surface:#F9FAFB;       /* alias */
  --surface-2:#F3F4F6;
  --surface-3:#E5E7EB;
  --border:#E5E7EB;        /* dark: #1F2937 -> light: gray-200 */
  --border-strong:#D1D5DB; /* dark: #2A3648 -> light: gray-300 */
  /* Textes : inversion. WCAG AA texte normal ratio >= 4.5:1. */
  --text:#111827;          /* dark: #F9FAFB -> light: gray-900 (vs #FFF : 16.9:1) */
  --text-muted:#4B5563;    /* dark: #9CA3AF -> light: gray-600 (vs #FFF : 7.4:1) */
  --text-faint:#6B7280;    /* dark: #6B7280 inchange (vs #FFF : 4.8:1, juste AA) */
  /* Primary : assombrissement subtil pour lisibilite sur fond clair. */
  --primary:#1D4ED8;       /* dark: #3B82F6 -> light: blue-700 (vs #FFF : 6.6:1) */
  --primary-hover:#1E40AF; /* dark: #60A5FA -> light: blue-800 */
  --primary-strong:#1B3A6B;/* preserve */
  --primary-soft:rgba(29,78,216,.10);
  /* Etats : conserves mais legerement assombris pour fond clair. */
  --success:#047857;       /* dark: #10B981 -> light: emerald-700 */
  --danger:#B91C1C;        /* dark: #EF4444 -> light: red-700 */
  --warning:#B45309;       /* dark: #F59E0B -> light: amber-700 */
  /* Ombres : moins opaques sur fond clair. */
  --shadow-sm:0 1px 2px rgba(0,0,0,.06);
  --shadow-md:0 8px 24px rgba(0,0,0,.08);
  --shadow-lg:0 16px 48px rgba(0,0,0,.10);
  /* ── Tokens metier (Q9 distinguabilite stricte) ──
     Conservation de la semantique noir/jaune/gris avec adaptation fond clair
     + ajout de tokens border dedies (cf. regle .label-block plus bas). */
  --noir-lbl:#1F2937;      /* dark: #3a3a3e -> light: gray-800 (preserve "noir") */
  --jaune:#FBBF24;         /* dark: #d4b73a -> light: amber-400 (preserve "jaune", saturation+) */
  --gris-lbl:#9CA3AF;      /* dark: #7e8893 -> light: gray-400 (preserve "gris", contraste fond) */
  --noir-lbl-border:#000000;
  --jaune-border:#92400E;  /* amber-800, contraste fort vs jaune saturé */
  --gris-lbl-border:#4B5563;/* gray-600 */
}"
`;

exports[`Q9 — figeage bloc :root[data-theme="light"] > planning-sav.html : bloc light fige 1`] = `
":root[data-theme="light"]{
  /* Surfaces : inversion. */
  --bg:#FFFFFF;            /* dark: #0A0F1E -> light: white */
  --bg-elev-1:#F9FAFB;     /* dark: #111827 -> light: gray-50 */
  --bg-elev-2:#F3F4F6;     /* dark: #0F1626 -> light: gray-100 */
  --bg-elev-3:#E5E7EB;     /* dark: #1A2233 -> light: gray-200 */
  --surface:#F9FAFB;
  --surface-2:#F3F4F6;
  --surface-3:#E5E7EB;
  --border:#E5E7EB;
  --border-strong:#D1D5DB;
  /* Textes : WCAG AA >=4.5:1. */
  --text:#111827;          /* vs #FFF: 16.9:1 */
  --text-muted:#4B5563;    /* vs #FFF: 7.4:1 */
  --text-faint:#6B7280;    /* vs #FFF: 4.8:1 */
  /* Primary : assombri pour fond clair. */
  --primary:#1B3A6B;       /* preserve (deja sombre) */
  --primary-hover:#2C5494;
  --primary-soft:rgba(27,58,107,.10);
  --accent-blue:#1D4ED8;   /* dark: #3B82F6 -> light: blue-700 */
  --success:#047857;
  --danger:#B91C1C;
  --warning:#B45309;
  --shadow-sm:0 1px 2px rgba(0,0,0,.06);
  --shadow-md:0 8px 24px rgba(0,0,0,.08);
  --shadow-lg:0 16px 48px rgba(0,0,0,.10);
  /* ── Tokens metier MONTAGE (cross-context lignes communes) ── */
  --noir-lbl:#1F2937;
  --jaune:#FBBF24;
  --gris-lbl:#9CA3AF;
  --noir-lbl-border:#000000;
  --jaune-border:#92400E;
  --gris-lbl-border:#4B5563;
  /* ── Tokens metier SAV (Q9 distinguabilite) ── */
  --sav-noir:#1F2937;      /* dark: #212121 -> light: gray-800 (preserve "noir/absent") */
  --sav-jaune:#FBBF24;     /* dark: #FDD835 -> light: amber-400 */
  --sav-gris:#9CA3AF;      /* dark: #90A4AE -> light: gray-400 */
  --sav-noir-border:#000000;
  --sav-jaune-border:#92400E;
  --sav-gris-border:#4B5563;
}"
`;
