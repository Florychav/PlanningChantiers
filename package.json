{
  "name": "planning-menetrey",
  "version": "0.0.0-refonte",
  "private": true,
  "type": "module",
  "description": "Planning Chantier Ascenseurs Menetrey - refonte ESM bundle (work in progress on branch refonte/esm-bundle)",
  "scripts": {
    "build": "node esbuild.config.mjs && node scripts/copy-static.mjs",
    "build:watch": "node esbuild.config.mjs --watch",
    "preview": "npx http-server dist -p 3000 -c-1",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit",
    "check:wcag": "node scripts/check-wcag.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "exceljs": "^4.4.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@types/node": "^25.8.0",
    "@vitest/coverage-v8": "^4.1.6",
    "esbuild": "^0.28.0",
    "jsdom": "^25.0.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.6"
  }
}
